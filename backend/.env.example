AZURE_OPENAI_ENDPOINT=https://<your-foundry-project>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
EMBEDDING_VECTOR_SIZE=1536  # Dimensions for text-embedding-ada-002; use 3072 for text-embedding-3-large
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_documents
API_KEY=<generate-a-secure-random-string>
CORS_ORIGINS=*
# Local development values. Docker Compose overrides QDRANT_URL, DATA_DIR, and
# BM25_INDEX_PATH via the environment: block in infra/docker-compose.yml.
# Do not change those values here for Docker — change docker-compose.yml instead.
DATA_DIR=data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=100
EMBEDDING_MAX_CONCURRENCY=3
# Seconds to sleep per concurrency slot after each batch — tune against your TPM quota
# At 150k TPM / 900 RPM: with batch_size=100 (~25k tokens/batch) set to ~10.0
EMBEDDING_INTER_BATCH_DELAY=1.0
BM25_INDEX_PATH=data/bm25_index.pkl
RETRIEVAL_TOP_K=10
RERANKER_TOP_K=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RRF_K=60
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
TAVILY_API_KEY=
# Chunking strategy: recursive_character | sentence_window | semantic
CHUNK_STRATEGY=recursive_character
# Tiktoken encoding for token-aware chunk splitting (matches text-embedding-ada-002)
CHUNK_TOKENIZER_MODEL=cl100k_base
# Path where RAGAS evaluation baseline JSON is persisted
EVAL_BASELINE_PATH=data/eval_baseline.json
