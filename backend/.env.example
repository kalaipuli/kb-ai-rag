AZURE_OPENAI_ENDPOINT=https://<your-foundry-project>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
EMBEDDING_VECTOR_SIZE=3072  # Dimensions for text-embedding-3-large; change if switching models
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_documents
API_KEY=<generate-a-secure-random-string>
CORS_ORIGINS=*
DATA_DIR=/app/data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=100
BM25_INDEX_PATH=/app/data/bm25_index.pkl
RETRIEVAL_TOP_K=10
RERANKER_TOP_K=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RRF_K=60
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
TAVILY_API_KEY=
